rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Maintenance Collections
    match /complaints/{id} {
      allow read, write: if true;
    }
    match /staff/{id} {
      allow read, write: if true;
    }
    match /emergencies/{id} {
      allow read, write: if true;
    }
    match /notifications/{id} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Legacy/Other Collections
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if true;
    }
    match /quiz_questions/{questionId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Default fallback (keep open until May 27 as per user's intent)
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 5, 27);
    }
  }
}
